# Agentic OS — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── Auth (required) ─────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
AGENTIC_OS_AUTH_SECRET=

# ── Admin account (optional) ──────────────────────────────────────────────
# Leave both empty → use the /setup onboarding wizard on first launch.
AGENTIC_OS_ADMIN_EMAIL=
AGENTIC_OS_ADMIN_PASSWORD_HASH=

# ── API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
ONEMINAI_API_KEY=

# ── Ollama (optional) ─────────────────────────────────────────────────────
# Defaults to host.docker.internal:11434 (Ollama running on your machine)
# OLLAMA_HOST=host.docker.internal
# OLLAMA_PORT=11434
# OLLAMA_PULL_MODELS=llama3.2:latest,qwen2.5-coder:7b
